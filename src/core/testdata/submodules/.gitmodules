[submodule "pyca.cryptography"]
    path = pyca-cryptography
    url = https://github.com/pyca/cryptography.git

# comment line
[submodule "krb5"]
    path = krb5
    url = https://github.com/krb5/krb5

[submodule "gost-engine"]
    path = gost-engine
    url = https://github.com/gost-engine/engine
    update = rebase
[submodule "fuzz/corpora"]
    path = fuzz/corpora
    url = https://github.com/openssl/fuzz-corpora
    branch = main
[submodule "wycheproof"] # ghat:suppress:reason=tracks main intentionally
    path = wycheproof
    url = https://github.com/google/wycheproof
[submodule "tlsfuzzer"]
    path = tlsfuzzer
    url = https://github.com/tlsfuzzer/tlsfuzzer # ghat:suppress
